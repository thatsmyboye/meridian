{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@meridian/api": ["../../packages/api/src/index.ts"],
      "@meridian/inngest": ["../../packages/inngest/src/index.ts"],
      "@meridian/types": ["../../packages/types/src/index.ts"],
      "@meridian/ui": ["../../packages/ui/src/index.tsx"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
