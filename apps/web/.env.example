NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Public base URL (no trailing slash) – used as the OAuth redirect_uri origin
# Production: https://meridian.banton-digital.com  |  Local dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://meridian.banton-digital.com

# Supabase Auth site_url (must match NEXT_PUBLIC_SITE_URL; used in supabase/config.toml via env(SITE_URL))
# Production: https://meridian.banton-digital.com  |  Local dev: http://127.0.0.1:3000
SITE_URL=https://meridian.banton-digital.com

# Google OAuth credentials for Supabase Auth (user sign-in)
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# ⚠️  "Unable to exchange external code" errors mean the redirect URI is missing — add ALL of:
#   Local dev : http://127.0.0.1:54321/auth/v1/callback
#   Production: https://ijtgwkdizngdssnnmrmw.supabase.co/auth/v1/callback
# These are consumed by supabase/config.toml → [auth.external.google]
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=<your-google-oauth-client-id>
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=<your-google-oauth-client-secret>

# YouTube / Google OAuth credentials (YouTube Data API access for connected platforms)
# Create a separate OAuth 2.0 Client ID or reuse the one above.
# Authorised redirect URI must include: <NEXT_PUBLIC_SITE_URL>/api/connect/youtube/callback
YOUTUBE_CLIENT_ID=<your-google-oauth-client-id>
YOUTUBE_CLIENT_SECRET=<your-google-oauth-client-secret>

# Instagram / Meta OAuth credentials
# Create a Meta App at https://developers.facebook.com/apps
# Add the "Instagram Graph API" product to your app.
# Under Facebook Login > Settings, add the following OAuth redirect URI:
#   <NEXT_PUBLIC_SITE_URL>/api/connect/instagram/callback
# Required scopes: instagram_basic, instagram_content_publish, instagram_manage_insights, pages_show_list, pages_read_engagement
# The connected Instagram account must be a Business or Creator account linked to a Facebook Page.
META_APP_ID=<your-meta-app-id>
META_APP_SECRET=<your-meta-app-secret>
# Webhook verify token – set this to any secret string, then enter the same value
# in the Meta App Dashboard under:
#   Webhooks (or Instagram > Webhooks) → Edit Subscription
#     Callback URL : <NEXT_PUBLIC_SITE_URL>/api/webhooks/instagram
#     Verify Token : <value of this env var>
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
META_WEBHOOK_VERIFY_TOKEN=<your-webhook-verify-token>

# Twitter / X OAuth 2.0 credentials
# Create an app at https://developer.twitter.com/en/portal/projects-and-apps
# Under "User authentication settings", enable OAuth 2.0 with:
#   Type of App: Web App, Automated App or Bot
#   Callback URI: <NEXT_PUBLIC_SITE_URL>/api/connect/twitter/callback
#   Website URL: <NEXT_PUBLIC_SITE_URL>
# Required permissions: tweet.read, tweet.write, users.read, offline.access
TWITTER_CLIENT_ID=<your-twitter-oauth2-client-id>
TWITTER_CLIENT_SECRET=<your-twitter-oauth2-client-secret>

# TikTok OAuth 2.0 credentials
# Create an app at https://developers.tiktok.com/apps
# Under "Login Kit", add the redirect URI:
#   <NEXT_PUBLIC_SITE_URL>/api/connect/tiktok/callback
# Required scopes: user.info.basic, user.info.profile, video.publish, video.upload
TIKTOK_CLIENT_KEY=<your-tiktok-client-key>
TIKTOK_CLIENT_SECRET=<your-tiktok-client-secret>
# Set to "true" when testing with a TikTok Sandbox app (pre-approval).
# Omits video.publish and video.upload scopes, which are unavailable in Sandbox.
# Must be "false" or unset in production.
TIKTOK_SANDBOX=false

# Patreon OAuth 2.0 credentials
# Create an app at https://www.patreon.com/portal/registration/register-clients
# Under "Redirect URIs", add:
#   <NEXT_PUBLIC_SITE_URL>/api/connect/patreon/callback
# Required scopes: identity, identity[email], campaigns, campaigns.posts, w:campaigns.posts
PATREON_CLIENT_ID=<your-patreon-client-id>
PATREON_CLIENT_SECRET=<your-patreon-client-secret>

# LinkedIn OAuth 2.0 credentials
# Create an app at https://www.linkedin.com/developers/apps
# Under "Auth", add the redirect URL:
#   <NEXT_PUBLIC_SITE_URL>/api/connect/linkedin/callback
# Required scopes: openid, profile, email, w_member_social, r_member_social
# Note: LinkedIn stopped approving new r_member_social requests as of early 2026.
#       Post-syncing (reading member posts) will not work for apps registered after
#       that date. Publishing posts (w_member_social) is unaffected.
# Note: LinkedIn does not issue refresh tokens; tokens are valid for 60 days.
LINKEDIN_CLIENT_ID=<your-linkedin-client-id>
LINKEDIN_CLIENT_SECRET=<your-linkedin-client-secret>

# AES-256-GCM key for encrypting OAuth tokens at rest (64 hex chars = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=<64-hex-char-key>

# Beehiiv – no server-side credentials required.
# Creators supply their own API key and publication ID via the /connect/beehiiv form.
# The API key is validated against https://api.beehiiv.com/v2 and stored encrypted.

# Substack – no server-side credentials required.
# Creators supply their publication URL via the /connect/substack form.
# Content is synced from the publication's public RSS feed ({url}/feed).
# Substack does not currently offer a first-party developer API; only public posts
# are accessible. Paid subscriber-only content and analytics are not available.

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Create products and prices at https://dashboard.stripe.com/products
#   Meridian Creator – $19/mo recurring
#   Meridian Pro     – $49/mo recurring
#
# Webhook endpoint: <NEXT_PUBLIC_SITE_URL>/api/stripe/webhook
# Events to send:
#   checkout.session.completed
#   customer.subscription.updated
#   customer.subscription.deleted
STRIPE_SECRET_KEY=sk_test_<your-stripe-secret-key>

# v1 webhook endpoint secret (snapshot payloads – full resource in data.object)
# Events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_<your-v1-stripe-webhook-signing-secret>

# v2 webhook endpoint secret (thin payloads – only a related_object reference)
# Only required if you register a separate v2 webhook destination in Stripe.
# Leave unset if you are not using v2 thin-payload event destinations.
STRIPE_V2_WEBHOOK_SECRET=whsec_<your-v2-stripe-webhook-signing-secret>

STRIPE_CREATOR_PRICE_ID=price_<creator-plan-price-id>
STRIPE_PRO_PRICE_ID=price_<pro-plan-price-id>

# ─── Inngest ────────────────────────────────────────────────────────────────────
# Signing key and event key from https://app.inngest.com/env/production/manage/signing-key
# INNGEST_SIGNING_KEY verifies that webhook requests come from Inngest servers
# INNGEST_EVENT_KEY is used when sending events from the app to Inngest
INNGEST_SIGNING_KEY=signkey-prod-<your-inngest-signing-key>
INNGEST_EVENT_KEY=<your-inngest-event-key>

# ─── AI / LLM ───────────────────────────────────────────────────────────────────
# Anthropic Claude – used for content derivative generation
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-<your-anthropic-api-key>

# OpenAI – used for audio transcription via Whisper
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-<your-openai-api-key>

# ─── Analytics ──────────────────────────────────────────────────────────────────
# PostHog – product analytics, performance monitoring, and AI usage tracking
# Create a project at https://posthog.com and copy the Project API key.
# NEXT_PUBLIC_ variables are exposed to the browser; POSTHOG_KEY is server-only.
NEXT_PUBLIC_POSTHOG_KEY=phc_<your-posthog-project-api-key>
# Default host works for PostHog Cloud US region. EU region: https://eu.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
# Server-side key used by Inngest background functions (same key, no NEXT_PUBLIC_ prefix)
POSTHOG_KEY=phc_<your-posthog-project-api-key>
POSTHOG_HOST=https://us.i.posthog.com

# ─── Email ──────────────────────────────────────────────────────────────────────
# Resend – used for transactional emails (weekly digest, publish notifications)
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=re_<your-resend-api-key>

# Public app URL used in email links (no trailing slash)
# Production: https://meridian.banton-digital.com  |  Local dev: http://localhost:3000
NEXT_PUBLIC_APP_URL=https://meridian.banton-digital.com
