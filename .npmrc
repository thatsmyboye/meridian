# Required for Expo/React Native compatibility with pnpm in a monorepo.
# shamefully-hoist hoists all packages to the workspace root node_modules,
# which is what Expo and Metro expect. See: https://docs.expo.dev/guides/monorepos/
shamefully-hoist=true

# Note: Root package.json uses pnpm.overrides to force a single React version
# across web (Next.js) and mobile (Expo). Without this, incompatible ranges
# would cause multiple React copies and "Invalid Hook Call" errors in shared
# packages like @meridian/ui.
